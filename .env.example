# Copy to .env and fill in real values. Do NOT commit the real .env.

# Server
NODE_ENV=production
PORT=3012

# Database (MySQL / MariaDB)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=disk_catalog
DB_USER=root
DB_PASSWORD=change_me

# Auth
JWT_SECRET=change_me_to_a_long_random_string

# Google OAuth (baked into the client at build time)
VITE_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
